<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">
  <bean id="root" class="com.telamin.fluxtion.test.performance.nodes.RootLinearNode"/>
  <bean id="node_1" class="com.telamin.fluxtion.test.performance.nodes.LinearNode">
    <property name="upstream1" ref="root"/>
  </bean>
  <bean id="node_2" class="com.telamin.fluxtion.test.performance.nodes.LinearNode">
    <property name="upstream1" ref="node_1"/>
  </bean>
  <bean id="node_3" class="com.telamin.fluxtion.test.performance.nodes.LinearNode">
    <property name="upstream1" ref="node_2"/>
  </bean>
  <bean id="node_4" class="com.telamin.fluxtion.test.performance.nodes.LinearNode">
    <property name="upstream1" ref="node_3"/>
  </bean>
  <bean id="node_5" class="com.telamin.fluxtion.test.performance.nodes.LinearNode">
    <property name="upstream1" ref="node_4"/>
  </bean>
  <bean id="sink" class="com.telamin.fluxtion.test.performance.nodes.LinearNodePublisher">
    <property name="upstream1" ref="node_5"/>
  </bean>
</beans>
