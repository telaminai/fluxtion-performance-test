<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

  <!-- === Market Data chain (MarketDataEvent -> BaseNode x 20) === -->
  <bean id="md_root" class="com.telamin.fluxtion.test.performance.nodes.MarketDataRootNode"/>
  <bean id="md_1" class="com.telamin.fluxtion.test.performance.nodes.BaseNode">
    <property name="upstream1" ref="md_root"/>
  </bean>
  <bean id="md_2" class="com.telamin.fluxtion.test.performance.nodes.BaseNode">
    <property name="upstream1" ref="md_1"/>
  </bean>
  <bean id="md_3" class="com.telamin.fluxtion.test.performance.nodes.BaseNode">
    <property name="upstream1" ref="md_2"/>
  </bean>
  <bean id="md_4" class="com.telamin.fluxtion.test.performance.nodes.BaseNode">
    <property name="upstream1" ref="md_3"/>
  </bean>
  <bean id="md_5" class="com.telamin.fluxtion.test.performance.nodes.BaseNode">
    <property name="upstream1" ref="md_4"/>
  </bean>
  <bean id="md_6" class="com.telamin.fluxtion.test.performance.nodes.BaseNode">
    <property name="upstream1" ref="md_5"/>
  </bean>
  <bean id="md_7" class="com.telamin.fluxtion.test.performance.nodes.BaseNode">
    <property name="upstream1" ref="md_6"/>
  </bean>
  <bean id="md_8" class="com.telamin.fluxtion.test.performance.nodes.BaseNode">
    <property name="upstream1" ref="md_7"/>
  </bean>
  <bean id="md_9" class="com.telamin.fluxtion.test.performance.nodes.BaseNode">
    <property name="upstream1" ref="md_8"/>
  </bean>
  <bean id="md_10" class="com.telamin.fluxtion.test.performance.nodes.BaseNode">
    <property name="upstream1" ref="md_9"/>
  </bean>
  <bean id="md_11" class="com.telamin.fluxtion.test.performance.nodes.BaseNode">
    <property name="upstream1" ref="md_10"/>
  </bean>
  <bean id="md_12" class="com.telamin.fluxtion.test.performance.nodes.BaseNode">
    <property name="upstream1" ref="md_11"/>
  </bean>
  <bean id="md_13" class="com.telamin.fluxtion.test.performance.nodes.BaseNode">
    <property name="upstream1" ref="md_12"/>
  </bean>
  <bean id="md_14" class="com.telamin.fluxtion.test.performance.nodes.BaseNode">
    <property name="upstream1" ref="md_13"/>
  </bean>
  <bean id="md_15" class="com.telamin.fluxtion.test.performance.nodes.BaseNode">
    <property name="upstream1" ref="md_14"/>
  </bean>
  <bean id="md_16" class="com.telamin.fluxtion.test.performance.nodes.BaseNode">
    <property name="upstream1" ref="md_15"/>
  </bean>
  <bean id="md_17" class="com.telamin.fluxtion.test.performance.nodes.BaseNode">
    <property name="upstream1" ref="md_16"/>
  </bean>
  <bean id="md_18" class="com.telamin.fluxtion.test.performance.nodes.BaseNode">
    <property name="upstream1" ref="md_17"/>
  </bean>
  <bean id="md_19" class="com.telamin.fluxtion.test.performance.nodes.BaseNode">
    <property name="upstream1" ref="md_18"/>
  </bean>
  <bean id="md_20" class="com.telamin.fluxtion.test.performance.nodes.BaseNode">
    <property name="upstream1" ref="md_19"/>
  </bean>
  <bean id="md_sink" class="com.telamin.fluxtion.test.performance.nodes.PublisherNode">
    <property name="upstream1" ref="md_20"/>
  </bean>

  <!-- === Trade Signal chain (TradeSignalEvent -> AccumulatorNode x 10) === -->
  <bean id="ts_root" class="com.telamin.fluxtion.test.performance.nodes.TradeSignalRootNode"/>
  <bean id="ts_1" class="com.telamin.fluxtion.test.performance.nodes.AccumulatorNode">
    <property name="upstream1" ref="ts_root"/>
  </bean>
  <bean id="ts_2" class="com.telamin.fluxtion.test.performance.nodes.AccumulatorNode">
    <property name="upstream1" ref="ts_1"/>
  </bean>
  <bean id="ts_3" class="com.telamin.fluxtion.test.performance.nodes.AccumulatorNode">
    <property name="upstream1" ref="ts_2"/>
  </bean>
  <bean id="ts_4" class="com.telamin.fluxtion.test.performance.nodes.AccumulatorNode">
    <property name="upstream1" ref="ts_3"/>
  </bean>
  <bean id="ts_5" class="com.telamin.fluxtion.test.performance.nodes.AccumulatorNode">
    <property name="upstream1" ref="ts_4"/>
  </bean>
  <bean id="ts_6" class="com.telamin.fluxtion.test.performance.nodes.AccumulatorNode">
    <property name="upstream1" ref="ts_5"/>
  </bean>
  <bean id="ts_7" class="com.telamin.fluxtion.test.performance.nodes.AccumulatorNode">
    <property name="upstream1" ref="ts_6"/>
  </bean>
  <bean id="ts_8" class="com.telamin.fluxtion.test.performance.nodes.AccumulatorNode">
    <property name="upstream1" ref="ts_7"/>
  </bean>
  <bean id="ts_9" class="com.telamin.fluxtion.test.performance.nodes.AccumulatorNode">
    <property name="upstream1" ref="ts_8"/>
  </bean>
  <bean id="ts_10" class="com.telamin.fluxtion.test.performance.nodes.AccumulatorNode">
    <property name="upstream1" ref="ts_9"/>
  </bean>
  <bean id="ts_sink" class="com.telamin.fluxtion.test.performance.nodes.PublisherNode">
    <property name="upstream1" ref="ts_10"/>
  </bean>

  <!-- === Control chain (ControlEvent -> FilteringNode x 5) === -->
  <bean id="ctrl_root" class="com.telamin.fluxtion.test.performance.nodes.ControlRootNode"/>
  <bean id="ctrl_1" class="com.telamin.fluxtion.test.performance.nodes.FilteringNode">
    <property name="upstream1" ref="ctrl_root"/>
  </bean>
  <bean id="ctrl_2" class="com.telamin.fluxtion.test.performance.nodes.FilteringNode">
    <property name="upstream1" ref="ctrl_1"/>
  </bean>
  <bean id="ctrl_3" class="com.telamin.fluxtion.test.performance.nodes.FilteringNode">
    <property name="upstream1" ref="ctrl_2"/>
  </bean>
  <bean id="ctrl_4" class="com.telamin.fluxtion.test.performance.nodes.FilteringNode">
    <property name="upstream1" ref="ctrl_3"/>
  </bean>
  <bean id="ctrl_5" class="com.telamin.fluxtion.test.performance.nodes.FilteringNode">
    <property name="upstream1" ref="ctrl_4"/>
  </bean>
  <bean id="ctrl_sink" class="com.telamin.fluxtion.test.performance.nodes.PublisherNode">
    <property name="upstream1" ref="ctrl_5"/>
  </bean>
</beans>
