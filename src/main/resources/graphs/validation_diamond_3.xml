    <property name="upstream2" ref="ctrl_root"/>
  </bean>
  <bean id="ctrl_l1_n2" class="com.telamin.fluxtion.test.performance.validation.nodes.ValidationBaseNode">
    <property name="nodeId" value="ctrl_l1_n2"/>
    <property name="eventContext" ref="eventContext"/>
    <property name="dataCollector" ref="dataCollector"/>
    <property name="upstream1" ref="ctrl_root"/>
    <property name="upstream2" ref="ctrl_root"/>
  </bean>
  <bean id="ctrl_l2_n0" class="com.telamin.fluxtion.test.performance.validation.nodes.ValidationAccumulatorNode">
    <property name="nodeId" value="ctrl_l2_n0"/>
    <property name="eventContext" ref="eventContext"/>
    <property name="dataCollector" ref="dataCollector"/>
    <property name="upstream1" ref="ctrl_l1_n0"/>
    <property name="upstream2" ref="ctrl_l1_n1"/>
  </bean>
  <bean id="ctrl_l2_n1" class="com.telamin.fluxtion.test.performance.validation.nodes.ValidationAccumulatorNode">
    <property name="nodeId" value="ctrl_l2_n1"/>
