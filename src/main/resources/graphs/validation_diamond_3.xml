<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

  <!-- shared infrastructure -->
  <bean id="eventContext" class="com.telamin.fluxtion.test.performance.validation.nodes.EventContext"/>
  <bean id="dataCollector" class="com.telamin.fluxtion.test.performance.validation.nodes.DataCollector"/>

  <!-- === MarketData chain: root -> 3 layers x 3 nodes/layer -> sink === -->
  <bean id="md_root" class="com.telamin.fluxtion.test.performance.validation.nodes.ValidationMarketRootNode">
    <property name="nodeId" value="md_root"/>
    <property name="eventContext" ref="eventContext"/>
    <property name="dataCollector" ref="dataCollector"/>
  </bean>
  <bean id="md_l1_n0" class="com.telamin.fluxtion.test.performance.validation.nodes.ValidationBaseNode">
    <property name="nodeId" value="md_l1_n0"/>
    <property name="eventContext" ref="eventContext"/>
    <property name="dataCollector" ref="dataCollector"/>
    <property name="upstream1" ref="md_root"/>
    <property name="upstream2" ref="md_root"/>
  </bean>
  <bean id="md_l1_n1" class="com.telamin.fluxtion.test.performance.validation.nodes.ValidationBaseNode">
    <property name="nodeId" value="md_l1_n1"/>
    <property name="eventContext" ref="eventContext"/>
    <property name="dataCollector" ref="dataCollector"/>
