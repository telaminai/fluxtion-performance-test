    <property name="upstream1" ref="md_l1_n2"/>
    <property name="upstream2" ref="md_l1_n0"/>
  </bean>
  <bean id="md_l3_n0" class="com.telamin.fluxtion.test.performance.validation.nodes.ValidationBaseNode">
    <property name="nodeId" value="md_l3_n0"/>
    <property name="eventContext" ref="eventContext"/>
    <property name="dataCollector" ref="dataCollector"/>
    <property name="upstream1" ref="md_l2_n0"/>
    <property name="upstream2" ref="md_l2_n1"/>
  </bean>
  <bean id="md_l3_n1" class="com.telamin.fluxtion.test.performance.validation.nodes.ValidationBaseNode">
