    <property name="eventContext" ref="eventContext"/>
    <property name="dataCollector" ref="dataCollector"/>
    <property name="upstream1" ref="md_root"/>
    <property name="upstream2" ref="md_root"/>
  </bean>
  <bean id="md_l2_n0" class="com.telamin.fluxtion.test.performance.validation.nodes.ValidationAccumulatorNode">
    <property name="nodeId" value="md_l2_n0"/>
    <property name="eventContext" ref="eventContext"/>
    <property name="dataCollector" ref="dataCollector"/>
    <property name="upstream1" ref="md_l1_n0"/>
    <property name="upstream2" ref="md_l1_n1"/>
  </bean>
  <bean id="md_l2_n1" class="com.telamin.fluxtion.test.performance.validation.nodes.ValidationAccumulatorNode">
