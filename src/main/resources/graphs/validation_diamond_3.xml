    <property name="nodeId" value="ts_l1_n1"/>
    <property name="eventContext" ref="eventContext"/>
    <property name="dataCollector" ref="dataCollector"/>
    <property name="upstream1" ref="ts_root"/>
    <property name="upstream2" ref="ts_root"/>
  </bean>
  <bean id="ts_l1_n2" class="com.telamin.fluxtion.test.performance.validation.nodes.ValidationBaseNode">
    <property name="nodeId" value="ts_l1_n2"/>
    <property name="eventContext" ref="eventContext"/>
    <property name="dataCollector" ref="dataCollector"/>
    <property name="upstream1" ref="ts_root"/>
    <property name="upstream2" ref="ts_root"/>
