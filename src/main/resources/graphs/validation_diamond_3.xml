    <property name="eventContext" ref="eventContext"/>
    <property name="dataCollector" ref="dataCollector"/>
    <property name="upstream1" ref="ts_l1_n0"/>
    <property name="upstream2" ref="ts_l1_n1"/>
  </bean>
  <bean id="ts_l2_n1" class="com.telamin.fluxtion.test.performance.validation.nodes.ValidationAccumulatorNode">
    <property name="nodeId" value="ts_l2_n1"/>
    <property name="eventContext" ref="eventContext"/>
    <property name="dataCollector" ref="dataCollector"/>
    <property name="upstream1" ref="ts_l1_n1"/>
