    <property name="dataCollector" ref="dataCollector"/>
    <property name="upstream1" ref="md_l2_n2"/>
    <property name="upstream2" ref="md_l2_n0"/>
  </bean>
  <bean id="md_sink" class="com.telamin.fluxtion.test.performance.validation.nodes.ValidationSinkNode">
    <property name="nodeId" value="md_sink"/>
    <property name="eventContext" ref="eventContext"/>
    <property name="dataCollector" ref="dataCollector"/>
    <property name="upstream1" ref="md_l3_n0"/>
  </bean>

  <!-- === TradeSignal chain: root -> 2 layers x 3 nodes/layer -> sink === -->
  <bean id="ts_root" class="com.telamin.fluxtion.test.performance.validation.nodes.ValidationTradeRootNode">
