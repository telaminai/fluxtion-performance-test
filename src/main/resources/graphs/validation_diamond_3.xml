    <property name="eventContext" ref="eventContext"/>
    <property name="dataCollector" ref="dataCollector"/>
    <property name="upstream1" ref="md_l1_n1"/>
    <property name="upstream2" ref="md_l1_n2"/>
  </bean>
  <bean id="md_l2_n2" class="com.telamin.fluxtion.test.performance.validation.nodes.ValidationAccumulatorNode">
