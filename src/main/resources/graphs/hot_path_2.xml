<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">
  <bean id="root" class="com.telamin.fluxtion.test.performance.nodes.MarketDataRootNode"/>
  <bean id="hot_0" class="com.telamin.fluxtion.test.performance.nodes.AccumulatorNode">
    <property name="upstream1" ref="root"/>
  </bean>
  <bean id="hot_1" class="com.telamin.fluxtion.test.performance.nodes.AccumulatorNode">
    <property name="upstream1" ref="hot_0"/>
  </bean>
  <bean id="hot_2" class="com.telamin.fluxtion.test.performance.nodes.AccumulatorNode">
    <property name="upstream1" ref="hot_1"/>
  </bean>
  <bean id="hot_3" class="com.telamin.fluxtion.test.performance.nodes.AccumulatorNode">
    <property name="upstream1" ref="hot_2"/>
  </bean>
  <bean id="hot_4" class="com.telamin.fluxtion.test.performance.nodes.AccumulatorNode">
    <property name="upstream1" ref="hot_3"/>
  </bean>
  <bean id="hot_5" class="com.telamin.fluxtion.test.performance.nodes.AccumulatorNode">
    <property name="upstream1" ref="hot_4"/>
  </bean>
  <bean id="hot_6" class="com.telamin.fluxtion.test.performance.nodes.AccumulatorNode">
    <property name="upstream1" ref="hot_5"/>
  </bean>
  <bean id="hot_7" class="com.telamin.fluxtion.test.performance.nodes.AccumulatorNode">
    <property name="upstream1" ref="hot_6"/>
  </bean>
  <bean id="hot_8" class="com.telamin.fluxtion.test.performance.nodes.AccumulatorNode">
    <property name="upstream1" ref="hot_7"/>
  </bean>
  <bean id="hot_9" class="com.telamin.fluxtion.test.performance.nodes.AccumulatorNode">
    <property name="upstream1" ref="hot_8"/>
  </bean>
  <bean id="sink_hot" class="com.telamin.fluxtion.test.performance.nodes.PublisherNode">
    <property name="upstream1" ref="hot_9"/>
  </bean>
  <bean id="cold_1_filter" class="com.telamin.fluxtion.test.performance.nodes.FilteringNode">
    <property name="upstream1" ref="root"/>
    <property name="threshold" value="1.0E15"/>
  </bean>
  <bean id="cold_1_0" class="com.telamin.fluxtion.test.performance.nodes.AccumulatorNode">
    <property name="upstream1" ref="cold_1_filter"/>
  </bean>
  <bean id="cold_1_1" class="com.telamin.fluxtion.test.performance.nodes.AccumulatorNode">
    <property name="upstream1" ref="cold_1_0"/>
  </bean>
  <bean id="cold_1_2" class="com.telamin.fluxtion.test.performance.nodes.AccumulatorNode">
    <property name="upstream1" ref="cold_1_1"/>
  </bean>
  <bean id="cold_1_3" class="com.telamin.fluxtion.test.performance.nodes.AccumulatorNode">
    <property name="upstream1" ref="cold_1_2"/>
  </bean>
  <bean id="cold_1_4" class="com.telamin.fluxtion.test.performance.nodes.AccumulatorNode">
    <property name="upstream1" ref="cold_1_3"/>
  </bean>
  <bean id="sink_cold_1" class="com.telamin.fluxtion.test.performance.nodes.PublisherNode">
    <property name="upstream1" ref="cold_1_4"/>
  </bean>
</beans>
